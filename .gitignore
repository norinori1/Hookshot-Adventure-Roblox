# ============================================================
# Roblox (Luau) Game Development .gitignore
# ============================================================

# ------------------------------------------------------------
# Roblox Studio — Place & Model files
# ------------------------------------------------------------
# Binary place files are large and not diff-friendly.
# Uncomment the lines below if you store your place in Studio
# rather than managing it through Rojo or a similar sync tool.
# *.rbxl
# *.rbxm

# XML place / model files generated by Roblox Studio
# (uncomment if you prefer not to track them in source control)
# *.rbxlx
# *.rbxmx

# Roblox Studio lock files (created while a place is open)
*.rbxl.lock
*.rbxlx.lock

# ------------------------------------------------------------
# Rojo — Filesystem sync tool
# ------------------------------------------------------------
# Build output directory produced by `rojo build`
build/

# Sourcemap generated by `rojo sourcemap`
sourcemap.json

# ------------------------------------------------------------
# Wally — Roblox package manager
# ------------------------------------------------------------
# Installed package directories (equivalent to node_modules)
Packages/
ServerPackages/
DevPackages/

# Wally lock file — commit this if you want reproducible builds,
# or ignore it for libraries. Typically committed for games.
# wally.lock

# ------------------------------------------------------------
# Rokit / Foreman — Toolchain version managers
# ------------------------------------------------------------
# Rokit/Foreman download cache and local binary links
.rokit/
.foreman/

# ------------------------------------------------------------
# roblox-ts — TypeScript to Luau transpiler
# ------------------------------------------------------------
# Transpiler output
out/

# TypeScript build info cache
*.tsbuildinfo

# npm / Node dependencies (used by roblox-ts projects)
node_modules/

# ------------------------------------------------------------
# Selene — Luau linter
# ------------------------------------------------------------
# Auto-generated standard library definition files
roblox.toml

# ------------------------------------------------------------
# Luau Language Server
# ------------------------------------------------------------
# Generated definition files
*.d.luau

# ------------------------------------------------------------
# Environment & secrets
# ------------------------------------------------------------
.env
.env.local
.env.*.local
secrets.json

# ------------------------------------------------------------
# OS-generated files
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ------------------------------------------------------------
# Editor & IDE files
# ------------------------------------------------------------
# Visual Studio Code
.vscode/

# JetBrains IDEs (IntelliJ, Rider, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
Session.vim
